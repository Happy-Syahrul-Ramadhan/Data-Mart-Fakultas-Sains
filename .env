# Airflow Core Settings
AIRFLOW_UID=50000
AIRFLOW_PROJ_DIR=.

# Airflow Web UI Credentials
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=airflow

# Additional Python packages (optional)
# Packages untuk ETL Pipeline dengan Google Sheets dan MySQL
_PIP_ADDITIONAL_REQUIREMENTS=gspread google-auth google-auth-oauthlib google-auth-httplib2 pandas mysql-connector-python
